{
  "name": "it-infra-security-guide-book",
  "version": "1.0.0",
  "description": "インフラエンジニアが日常的に直面する横断的なセキュリティ実装課題を包括的に扱った実践書。設定の背景にある設計思想と実装判断の根拠を丁寧に言葉で説明することに重点を置いています。",
  "main": "index.md",
  "scripts": {
    "start": "bash scripts/jekyll.sh serve",
    "build": "bash scripts/jekyll.sh build",
    "test": "npm run check:security && npm run check:metadata && npm run check:reader-ux && npm run check:forensics-memory && npm run check:container-images && npm run lint && npm run check-links",
    "lint": "markdownlint -c .markdownlint.json \"docs/**/*.md\"",
    "check-links": "find docs -name '*.md' -print0 | xargs -0 -n 1 markdown-link-check -c .markdown-link-check.json",
    "deploy": "gh-pages -d _site",
    "check:metadata": "node scripts/check-metadata-consistency.js",
    "check:security": "npm audit",
    "check:forensics-memory": "node scripts/check-forensics-memory-sync.js",
    "check:container-images": "node scripts/check-container-image-pinning.js",
    "check:reader-ux": "node scripts/check-reader-ux.js && node scripts/check-reader-ux-regression.js"
  },
  "keywords": [
    "book",
    "documentation",
    "ja"
  ],
  "author": "株式会社アイティードゥ",
  "license": "CC-BY-NC-SA-4.0",
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli": "^0.48.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/itdojp/it-infra-security-guide-book.git"
  },
  "homepage": "https://itdojp.github.io/it-infra-security-guide-book/",
  "bugs": {
    "url": "https://github.com/itdojp/it-infra-security-guide-book/issues"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "overrides": {
    "js-yaml": "4.3.0",
    "markdown-it": "14.2.0",
    "linkify-it": "5.0.1",
    "undici": "7.28.0"
  }
}
